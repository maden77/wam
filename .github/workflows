name: Build Flutter APK

on:
  push:
    branches: [ main ] # Jalankan setiap kali kamu push ke branch main

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      
      - name: Setup Java
        uses: actions/setup-java@v4
        with:
          distribution: 'zulu'
          java-version: '17'
          
      - name: Setup Flutter
        uses: subosito/flutter-action@v2
        with:
          channel: 'stable'
          
      - name: Ambil Dependencies
        run: flutter pub get
        
      - name: Build APK
        run: flutter build apk --debug # --debug agar cepat, gunakan --release untuk hasil akhir
        
      - name: Upload APK ke GitHub
        uses: actions/upload-artifact@v4
        with:
          name: aplikasi-catatan
          path: build/app/outputs/flutter-apk/app-debug.apk
